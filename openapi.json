                  "$ref": "#/components/schemas/MessageOutputDto"
                },
                {
                  "$ref": "#/components/schemas/ToolCallOutputDto"
                },
                {
                  "$ref": "#/components/schemas/ReasoningOutputDto"
                },
                {
