          "total_output_tokens",
          "reasoning_output_tokens",
          "tokens_per_second",
          "time_to_first_token_seconds"
        ]
      },
      "ChatResponseDto": {
        "type": "object",
        "properties": {
          "model_instance_id": {
            "type": "string",
            "description": "Loaded model instance that generated the response"
          },
          "output": {
            "description": "Array of output items",
            "type": "array",
            "items": {
              "oneOf": [
