            "type": "object"
          },
          "output": {
            "type": "string"
          },
          "provider_info": {
            "$ref": "#/components/schemas/ProviderInfoDto"
          }
        },
        "required": [
          "type",
          "tool",
          "arguments",
          "output",
          "provider_info"
        ]
      },
      "ReasoningOutputDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
