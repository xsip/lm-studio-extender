          "tool_name"
        ]
      },
      "InvalidToolCallOutputDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "invalid_tool_call"
            ]
          },
          "reason": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/InvalidToolCallMetadataDto"
          }
        },
        "required": [
          "type",
          "reason",
          "metadata"
        ]
      },
      "ChatStatsDto": {
        "type": "object",
        "properties": {
          "input_tokens": {
            "type": "number",
