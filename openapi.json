  "info": {
    "title": "LMStudio Wrapper API",
    "description": "REST API for LM Studio Wrapper",
    "version": "2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "TextInputDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "message"
            ]
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "content"
        ]
      },
      "ImageInputDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "image"
            ]
          },
          "data_url": {
            "type": "string",
            "description": "Base64-encoded data URL of the image"
          }
        },
        "required": [
          "type",
          "data_url"
        ]
      },
      "PluginIntegrationDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "plugin"
            ]
          },
          "id": {
            "type": "string"
          },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "type",
          "id"
        ]
      },
      "EphemeralMcpIntegrationDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ephemeral_mcp"
            ]
          },
          "server_label": {
            "type": "string"
          },
          "server_url": {
            "type": "string"
          },
          "allowed_tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "headers": {
            "type": "object",
            "description": "Custom HTTP headers sent to the MCP server"
          }
        },
        "required": [
          "type",
          "server_label",
          "server_url"
        ]
      },
      "QuantizationDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "object",
            "nullable": true
          },
          "bits_per_weight": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "name",
          "bits_per_weight"
        ]
      },
      "LoadedInstanceConfigDto": {
        "type": "object",
        "properties": {
          "context_length": {
            "type": "number"
          },
          "eval_batch_size": {
            "type": "number"
          },
          "flash_attention": {
            "type": "boolean"
          },
          "num_experts": {
            "type": "number"
          },
          "offload_kv_cache_to_gpu": {
            "type": "boolean"
          }
        },
        "required": [
          "context_length"
        ]
      },
      "LoadedInstanceDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "config": {
            "$ref": "#/components/schemas/LoadedInstanceConfigDto"
          }
        },
        "required": [
          "id",
          "config"
        ]
      },
      "ModelCapabilitiesDto": {
        "type": "object",
        "properties": {
          "vision": {
            "type": "boolean"
          },
          "trained_for_tool_use": {
            "type": "boolean"
          }
        },
        "required": [
          "vision",
          "trained_for_tool_use"
        ]
      },
      "ModelDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "llm",
              "embedding"
            ]
          },
          "publisher": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "architecture": {
            "type": "object",
            "nullable": true
          },
          "quantization": {
            "nullable": true,
            "allOf": [
              {
                "$ref": "#/components/schemas/QuantizationDto"
              }
            ]
          },
          "size_bytes": {
            "type": "number"
          },
          "params_string": {
            "type": "object",
            "nullable": true
          },
          "loaded_instances": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LoadedInstanceDto"
            }
          },
          "max_context_length": {
            "type": "number"
          },
          "format": {
            "type": "string",
            "enum": [
              "gguf",
              "mlx"
            ],
            "nullable": true
          },
          "capabilities": {
            "$ref": "#/components/schemas/ModelCapabilitiesDto"
          },
          "description": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "type",
          "publisher",
          "key",
          "display_name",
          "quantization",
          "size_bytes",
          "params_string",
          "loaded_instances",
          "max_context_length",
          "format"
        ]
      },
      "ModelsResponseDto": {
        "type": "object",
        "properties": {
          "models": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ModelDto"
            }
          }
        },
        "required": [
          "models"
        ]
      },
      "ChatRequestDto": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Unique identifier for the model to use"
          },
          "input": {
            "description": "Message(s) to send to the model",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TextInputDto"
                    },
                    {
                      "$ref": "#/components/schemas/ImageInputDto"
                    }
                  ]
                }
              }
            ]
          },
          "system_prompt": {
            "type": "string",
            "description": "System prompt that sets model behaviour"
          },
          "integrations": {
            "type": "array",
            "description": "Integrations (plugins / ephemeral MCP servers) to enable",
            "items": {
              "oneOf": [
                {
                  "$ref": "#/components/schemas/PluginIntegrationDto"
                },
                {
                  "$ref": "#/components/schemas/EphemeralMcpIntegrationDto"
                }
              ]
            }
          },
          "stream": {
            "type": "boolean",
            "description": "Stream partial outputs via SSE",
            "default": false
          },
          "temperature": {
            "type": "number",
            "description": "Sampling temperature [0,1]"
          },
          "top_p": {
            "type": "number",
            "description": "Nucleus sampling probability [0,1]"
          },
          "top_k": {
            "type": "number",
            "description": "Top-k most probable tokens"
          },
          "min_p": {
            "type": "number",
            "description": "Minimum base probability for token selection [0,1]"
          },
          "repeat_penalty": {
            "type": "number",
            "description": "Repetition penalty (1 = no penalty)"
          },
          "max_output_tokens": {
            "type": "number",
            "description": "Maximum number of tokens to generate"
          },
          "reasoning": {
            "type": "string",
            "enum": [
              "off",
              "low",
              "medium",
              "high",
              "on"
            ],
            "description": "Reasoning effort level"
          },
          "context_length": {
            "type": "number",
            "description": "Context length in tokens (recommended to raise for MCP usage)"
          },
          "store": {
            "type": "boolean",
            "description": "Whether to persist the chat and return a response_id",
            "default": true
          },
          "previous_response_id": {
            "type": "string",
            "description": "Previous response ID to continue a stored conversation (must start with \"resp_\")"
          }
        },
        "required": [
          "model",
          "input"
        ]
      },
      "MessageOutputDto": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "message"
            ]
          },
          "content": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "content"
        ]
      },
      "ProviderInfoDto": {
        "type": "object",
