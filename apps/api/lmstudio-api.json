{
  "openapi": "3.0.3",
  "info": {
    "title": "LM Studio REST API",
    "description": "LM Studio v1 REST API with enhanced stats and rich model information. Requires LM Studio 0.3.6 or newer.",
    "version": "0",
    "contact": {
      "url": "https://github.com/lmstudio-ai/lmstudio-bug-tracker/issues"
    }
  },
  "servers": [
    {
      "url": "http://localhost:1234",
      "description": "Local LM Studio server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v0/models": {
      "get": {
        "summary": "List Models",
        "description": "List all loaded and downloaded models.",
        "operationId": "listModels",
        "tags": ["Models"],
        "responses": {
          "200": {
            "description": "A list of available models.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelList"
                },
                "example": {
                  "object": "list",
                  "data": [
                    {
                      "id": "qwen2-vl-7b-instruct",
                      "object": "model",
                      "type": "vlm",
                      "publisher": "mlx-community",
                      "arch": "qwen2_vl",
                      "compatibility_type": "mlx",
                      "quantization": "4bit",
                      "state": "not-loaded",
                      "max_context_length": 32768
                    },
                    {
                      "id": "meta-llama-3.1-8b-instruct",
                      "object": "model",
                      "type": "llm",
                      "publisher": "lmstudio-community",
                      "arch": "llama",
                      "compatibility_type": "gguf",
                      "quantization": "Q4_K_M",
                      "state": "not-loaded",
                      "max_context_length": 131072
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/models/{model}": {
      "get": {
        "summary": "Get Model",
        "description": "Get info about one specific model.",
        "operationId": "getModel",
        "tags": ["Models"],
        "parameters": [
          {
            "name": "model",
            "in": "path",
            "required": true,
            "description": "The model ID.",
            "schema": {
              "type": "string"
            },
            "example": "qwen2-vl-7b-instruct"
          }
        ],
        "responses": {
          "200": {
            "description": "Model details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Model"
                },
                "example": {
                  "id": "qwen2-vl-7b-instruct",
                  "object": "model",
                  "type": "vlm",
                  "publisher": "mlx-community",
                  "arch": "qwen2_vl",
                  "compatibility_type": "mlx",
                  "quantization": "4bit",
                  "state": "not-loaded",
                  "max_context_length": 32768
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/chat/completions": {
      "post": {
        "summary": "Chat Completions",
        "description": "Chat Completions API. Provide a messages array and receive the next assistant response.",
        "operationId": "createChatCompletion",
        "tags": ["Completions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatCompletionRequest"
              },
              "example": {
                "model": "granite-3.0-2b-instruct",
                "messages": [
                  { "role": "system", "content": "Always answer in rhymes." },
                  { "role": "user", "content": "Introduce yourself." }
                ],
                "temperature": 0.7,
                "max_tokens": -1,
                "stream": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Chat completion response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatCompletionResponse"
                },
                "example": {
                  "id": "chatcmpl-i3gkjwthhw96whukek9tz",
                  "object": "chat.completion",
                  "created": 1731990317,
                  "model": "granite-3.0-2b-instruct",
                  "choices": [
                    {
                      "index": 0,
                      "logprobs": null,
                      "finish_reason": "stop",
                      "message": {
                        "role": "assistant",
                        "content": "Greetings, I'm a helpful AI, here to assist."
                      }
                    }
                  ],
                  "usage": {
                    "prompt_tokens": 24,
                    "completion_tokens": 53,
                    "total_tokens": 77
                  },
                  "stats": {
                    "tokens_per_second": 51.43,
                    "time_to_first_token": 0.111,
                    "generation_time": 0.954,
                    "stop_reason": "eosFound"
                  },
                  "model_info": {
                    "arch": "granite",
                    "quant": "Q4_K_M",
                    "format": "gguf",
                    "context_length": 4096
                  },
                  "runtime": {
                    "name": "llama.cpp-mac-arm64-apple-metal-advsimd",
                    "version": "1.3.0",
                    "supported_formats": ["gguf"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/completions": {
      "post": {
        "summary": "Text Completions",
        "description": "Text Completions API. Provide a prompt and receive a completion.",
        "operationId": "createCompletion",
        "tags": ["Completions"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompletionRequest"
              },
              "example": {
                "model": "granite-3.0-2b-instruct",
                "prompt": "the meaning of life is",
                "temperature": 0.7,
                "max_tokens": 10,
                "stream": false,
                "stop": "\n"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Text completion response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompletionResponse"
                },
                "example": {
                  "id": "cmpl-p9rtxv6fky2v9k8jrd8cc",
                  "object": "text_completion",
                  "created": 1731990488,
                  "model": "granite-3.0-2b-instruct",
                  "choices": [
                    {
                      "index": 0,
                      "text": " to find your purpose, and once you have",
                      "logprobs": null,
                      "finish_reason": "length"
                    }
                  ],
                  "usage": {
                    "prompt_tokens": 5,
                    "completion_tokens": 9,
                    "total_tokens": 14
                  },
                  "stats": {
                    "tokens_per_second": 57.69,
                    "time_to_first_token": 0.299,
                    "generation_time": 0.156,
                    "stop_reason": "maxPredictedTokensReached"
                  },
                  "model_info": {
                    "arch": "granite",
                    "quant": "Q4_K_M",
                    "format": "gguf",
                    "context_length": 4096
                  },
                  "runtime": {
                    "name": "llama.cpp-mac-arm64-apple-metal-advsimd",
                    "version": "1.3.0",
                    "supported_formats": ["gguf"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v0/embeddings": {
      "post": {
        "summary": "Text Embeddings",
        "description": "Text Embeddings API. Provide text and receive its vector embedding representation.",
        "operationId": "createEmbedding",
        "tags": ["Embeddings"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmbeddingRequest"
              },
              "example": {
                "model": "text-embedding-nomic-embed-text-v1.5",
                "input": "Some text to embed"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Embedding response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmbeddingResponse"
                },
                "example": {
                  "object": "list",
                  "data": [
                    {
                      "object": "embedding",
                      "embedding": [-0.0167, 0.0284, -0.1407],
                      "index": 0
                    }
                  ],
                  "model": "text-embedding-nomic-embed-text-v1.5@q4_k_m",
                  "usage": {
                    "prompt_tokens": 0,
                    "total_tokens": 0
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Bearer token authentication. Use your LM Studio API token."
      }
    },
    "schemas": {
      "Model": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique model identifier.",
            "example": "meta-llama-3.1-8b-instruct"
          },
          "object": {
            "type": "string",
            "description": "Object type, always 'model'.",
            "example": "model"
          },
          "type": {
            "type": "string",
            "description": "Model type.",
            "enum": ["llm", "vlm", "embeddings"],
            "example": "llm"
          },
          "publisher": {
            "type": "string",
            "description": "Publisher or organization that released the model.",
            "example": "lmstudio-community"
          },
          "arch": {
            "type": "string",
            "description": "Model architecture.",
            "example": "llama"
          },
          "compatibility_type": {
            "type": "string",
            "description": "Runtime compatibility format.",
            "enum": ["gguf", "mlx"],
            "example": "gguf"
          },
          "quantization": {
            "type": "string",
            "description": "Quantization level of the model.",
            "example": "Q4_K_M"
          },
          "state": {
            "type": "string",
            "description": "Current load state of the model.",
            "enum": ["loaded", "not-loaded"],
            "example": "not-loaded"
          },
          "max_context_length": {
            "type": "integer",
            "description": "Maximum context window size in tokens.",
            "example": 131072
          }
        },
        "required": [
          "id",
          "object",
          "type",
          "publisher",
          "arch",
          "compatibility_type",
          "quantization",
          "state",
          "max_context_length"
        ]
      },
      "ModelList": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "example": "list"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Model"
            }
          }
        },
        "required": ["object", "data"]
      },
      "ChatMessage": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"],
            "description": "The role of the message author."
          },
          "content": {
            "type": "string",
            "description": "The content of the message."
          }
        },
        "required": ["role", "content"]
      },
      "ChatCompletionRequest": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "ID of the model to use.",
            "example": "granite-3.0-2b-instruct"
          },
          "messages": {
            "type": "array",
            "description": "List of messages forming the conversation so far.",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            }
          },
          "temperature": {
            "type": "number",
            "description": "Sampling temperature between 0 and 2. Higher values make output more random.",
            "minimum": 0,
            "maximum": 2,
            "default": 0.7,
            "example": 0.7
          },
          "max_tokens": {
            "type": "integer",
            "description": "Maximum number of tokens to generate. Use -1 for unlimited.",
            "default": -1,
            "example": -1
          },
          "stream": {
            "type": "boolean",
            "description": "Whether to stream the response.",
            "default": false,
            "example": false
          },
          "stop": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Stop sequence(s) at which to stop generation.",
            "example": "\n"
          }
        },
        "required": ["model", "messages"]
      },
      "CompletionRequest": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "ID of the model to use.",
            "example": "granite-3.0-2b-instruct"
          },
          "prompt": {
            "type": "string",
            "description": "The prompt to complete.",
            "example": "the meaning of life is"
          },
          "temperature": {
            "type": "number",
            "description": "Sampling temperature between 0 and 2.",
            "minimum": 0,
            "maximum": 2,
            "default": 0.7,
            "example": 0.7
          },
          "max_tokens": {
            "type": "integer",
            "description": "Maximum number of tokens to generate. Use -1 for unlimited.",
            "default": -1,
            "example": 10
          },
          "stream": {
            "type": "boolean",
            "description": "Whether to stream the response.",
            "default": false,
            "example": false
          },
          "stop": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Stop sequence(s) at which to stop generation.",
            "example": "\n"
          }
        },
        "required": ["model", "prompt"]
      },
      "EmbeddingRequest": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "ID of the embedding model to use.",
            "example": "text-embedding-nomic-embed-text-v1.5"
          },
          "input": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ],
            "description": "Text or array of texts to embed.",
            "example": "Some text to embed"
          }
        },
        "required": ["model", "input"]
      },
      "GenerationStats": {
        "type": "object",
        "description": "Enhanced generation statistics specific to LM Studio.",
        "properties": {
          "tokens_per_second": {
            "type": "number",
            "description": "Tokens generated per second.",
            "example": 51.43
          },
          "time_to_first_token": {
            "type": "number",
            "description": "Time in seconds until the first token was generated (TTFT).",
            "example": 0.111
          },
          "generation_time": {
            "type": "number",
            "description": "Total generation time in seconds.",
            "example": 0.954
          },
          "stop_reason": {
            "type": "string",
            "description": "Reason generation stopped.",
            "enum": [
              "eosFound",
              "maxPredictedTokensReached",
              "stopStringFound"
            ],
            "example": "eosFound"
          }
        }
      },
      "ModelInfo": {
        "type": "object",
        "description": "Information about the model used for generation.",
        "properties": {
          "arch": {
            "type": "string",
            "description": "Model architecture.",
            "example": "granite"
          },
          "quant": {
            "type": "string",
            "description": "Quantization level.",
            "example": "Q4_K_M"
          },
          "format": {
            "type": "string",
            "description": "Model format.",
            "example": "gguf"
          },
          "context_length": {
            "type": "integer",
            "description": "Context window length in tokens.",
            "example": 4096
          }
        }
      },
      "RuntimeInfo": {
        "type": "object",
        "description": "Information about the runtime used for inference.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Runtime identifier.",
            "example": "llama.cpp-mac-arm64-apple-metal-advsimd"
          },
          "version": {
            "type": "string",
            "description": "Runtime version.",
            "example": "1.3.0"
          },
          "supported_formats": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of model formats supported by this runtime.",
            "example": ["gguf"]
          }
        }
      },
      "UsageStats": {
        "type": "object",
        "properties": {
          "prompt_tokens": {
            "type": "integer",
            "description": "Number of tokens in the prompt.",
            "example": 24
          },
          "completion_tokens": {
            "type": "integer",
            "description": "Number of tokens in the completion.",
            "example": 53
          },
          "total_tokens": {
            "type": "integer",
            "description": "Total tokens used.",
            "example": 77
          }
        }
      },
      "ChatCompletionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique completion ID.",
            "example": "chatcmpl-i3gkjwthhw96whukek9tz"
          },
          "object": {
            "type": "string",
            "description": "Object type.",
            "example": "chat.completion"
          },
          "created": {
            "type": "integer",
            "description": "Unix timestamp of when the completion was created.",
            "example": 1731990317
          },
          "model": {
            "type": "string",
            "description": "Model used for this completion.",
            "example": "granite-3.0-2b-instruct"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "index": { "type": "integer", "example": 0 },
                "logprobs": { "nullable": true, "example": null },
                "finish_reason": {
                  "type": "string",
                  "enum": ["stop", "length", "content_filter"],
                  "example": "stop"
                },
                "message": {
                  "$ref": "#/components/schemas/ChatMessage"
                }
              }
            }
          },
          "usage": {
            "$ref": "#/components/schemas/UsageStats"
          },
          "stats": {
            "$ref": "#/components/schemas/GenerationStats"
          },
          "model_info": {
            "$ref": "#/components/schemas/ModelInfo"
          },
          "runtime": {
            "$ref": "#/components/schemas/RuntimeInfo"
          }
        }
      },
      "CompletionResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique completion ID.",
            "example": "cmpl-p9rtxv6fky2v9k8jrd8cc"
          },
          "object": {
            "type": "string",
            "description": "Object type.",
            "example": "text_completion"
          },
          "created": {
            "type": "integer",
            "description": "Unix timestamp of when the completion was created.",
            "example": 1731990488
          },
          "model": {
            "type": "string",
            "description": "Model used for this completion.",
            "example": "granite-3.0-2b-instruct"
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "index": { "type": "integer", "example": 0 },
                "text": {
                  "type": "string",
                  "description": "The generated text.",
                  "example": " to find your purpose, and once you have"
                },
                "logprobs": { "nullable": true, "example": null },
                "finish_reason": {
                  "type": "string",
                  "enum": ["stop", "length", "content_filter"],
                  "example": "length"
                }
              }
            }
          },
          "usage": {
            "$ref": "#/components/schemas/UsageStats"
          },
          "stats": {
            "$ref": "#/components/schemas/GenerationStats"
          },
          "model_info": {
            "$ref": "#/components/schemas/ModelInfo"
          },
          "runtime": {
            "$ref": "#/components/schemas/RuntimeInfo"
          }
        }
      },
      "EmbeddingResponse": {
        "type": "object",
        "properties": {
          "object": {
            "type": "string",
            "example": "list"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "object": {
                  "type": "string",
                  "example": "embedding"
                },
                "embedding": {
                  "type": "array",
                  "items": { "type": "number" },
                  "description": "The embedding vector."
                },
                "index": {
                  "type": "integer",
                  "description": "Index of this embedding in the batch.",
                  "example": 0
                }
              }
            }
          },
          "model": {
            "type": "string",
            "description": "Model used, including quantization suffix.",
            "example": "text-embedding-nomic-embed-text-v1.5@q4_k_m"
          },
          "usage": {
            "$ref": "#/components/schemas/UsageStats"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Models",
      "description": "List and inspect available models."
    },
    {
      "name": "Completions",
      "description": "Chat and text completion endpoints."
    },
    {
      "name": "Embeddings",
      "description": "Generate text embeddings."
    }
  ]
}
